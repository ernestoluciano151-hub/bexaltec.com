# ─── Bexaltec — Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in the real values.
# Add all these to Vercel → Project → Settings → Environment Variables.

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/bexaltec?sslmode=require"

# ── JWT Secret ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-key-min-32-chars-here"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://www.bexaltec.com"
NODE_ENV="production"
