# ── FORMSPREE (formulário de orçamento) ─────────────────────────
# Criar conta gratuita em formspree.io e criar um novo form
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here

# ── SUPABASE (auth + base de dados) ─────────────────────────────
# Criar projeto gratuito em supabase.com
# Em seguida: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── CONFIGURAÇÕES GERAIS ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bexaltec.ao
NEXT_PUBLIC_COMPANY_EMAIL=info@bexaltec.ao
NEXT_PUBLIC_COMPANY_PHONE=+244900000000
NEXT_PUBLIC_WHATSAPP=244900000000
